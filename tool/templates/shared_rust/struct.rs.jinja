{% extends "base.rs.jinja" %}
{%- block type_def -%}
#[repr(C)]
pub struct {{type_name -}}

{{- self.generic_lifetimes(true) -}}

{%- if fields.len() > 0 %} {
    {%- for f in fields %}
    pub {{f.name}}: {{f.type_info.render_with_override(lifetime_env, f.abi_type_info)}},
    {%- endfor %}
} {%- else -%};{%- endif %}

{%- endblock -%}

{%- block extra_impl -%}
{%- endblock -%}