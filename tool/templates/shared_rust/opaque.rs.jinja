{%- extends "base.rs.jinja" -%}

{%- block type_def -%}
{%- let lifetimes = self.lifetime_env.all_lifetimes().collect::<Vec<_>>() -%}
{%- if lifetimes.len() > 0 -%} use std::marker::PhantomData;

{% endif -%}

{#- Eventually, if https://rust-lang.github.io/rfcs/1861-extern-types.html is implemented, we'll want to switch to that. -#}
#[repr(C)]
pub struct {{type_name}}{{self.generic_lifetimes(true)}} {
    {%- for lt in lifetimes %}
    {{ lifetime_env.fmt_lifetime(*lt) }}_marker : PhantomData<&'{{lifetime_env.fmt_lifetime(*lt)}} ()>,
    {%- endfor %}
    _inner : ()
}

impl{{self.generic_lifetimes(false)}} Drop for {{type_name}}{{self.generic_lifetimes(false)}} {
    fn drop(&mut self) {
        unsafe { {{dtor_abi}}(self) }
    }
}
{%- endblock %}

{%- block abi_methods %}
    fn {{dtor_abi}}(this : *mut {{type_name}});
{% endblock -%}